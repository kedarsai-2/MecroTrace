<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260324170000-1" author="cursor">
        <addColumn tableName="lot">
            <column name="lot_serial_no" type="integer"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260324170000-2" author="cursor" dbms="postgresql">
        <sql>
            WITH ordered_lots AS (
                SELECT
                    id,
                    ((ROW_NUMBER() OVER (PARTITION BY seller_vehicle_id ORDER BY created_at, id) - 1) % 9999) + 1 AS computed_serial
                FROM lot
            )
            UPDATE lot
            SET lot_serial_no = ordered_lots.computed_serial
            FROM ordered_lots
            WHERE lot.id = ordered_lots.id
              AND lot.lot_serial_no IS NULL;
        </sql>
    </changeSet>

    <changeSet id="20260324170000-3" author="cursor">
        <addNotNullConstraint tableName="lot" columnName="lot_serial_no" columnDataType="integer"/>
    </changeSet>
</databaseChangeLog>
