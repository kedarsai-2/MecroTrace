<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Composite indexes for Daily Sales Summary and similar trader+date range reports -->
    <changeSet id="20260415120000-1" author="mercotrace">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_sales_bill_trader_bill_date" tableName="sales_bill"/>
            </not>
        </preConditions>
        <createIndex tableName="sales_bill" indexName="idx_sales_bill_trader_bill_date">
            <column name="trader_id"/>
            <column name="bill_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="20260415120000-2" author="mercotrace">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_vehicle_trader_arrival_datetime" tableName="vehicle"/>
            </not>
        </preConditions>
        <createIndex tableName="vehicle" indexName="idx_vehicle_trader_arrival_datetime">
            <column name="trader_id"/>
            <column name="arrival_datetime"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
