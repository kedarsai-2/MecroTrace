<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Optional SGST/CGST/IGST split percentages (nullable). -->
    <changeSet id="20260404120000-commodity-config-sgst-cgst-igst" author="mercotrace">
        <addColumn tableName="commodity_config">
            <column name="sgst_rate" type="double precision"/>
            <column name="cgst_rate" type="double precision"/>
            <column name="igst_rate" type="double precision"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
