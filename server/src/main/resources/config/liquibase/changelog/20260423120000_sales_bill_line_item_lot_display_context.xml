<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Lot identifier context for billing UI (formatAuctionLotIdentifier); independent of billed line quantity. -->
    <changeSet id="20260423120000-1" author="mercotrace">
        <addColumn tableName="sales_bill_line_item">
            <column name="lot_total_qty" type="int"/>
            <column name="vehicle_total_qty" type="int"/>
            <column name="seller_vehicle_qty" type="int"/>
            <column name="vehicle_mark" type="varchar(32)"/>
            <column name="seller_mark" type="varchar(32)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
