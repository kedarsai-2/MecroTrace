<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Post-auction Summary "new seller rate": independent from buyer_rate / bid_rate for vehicle-ops edits. -->
    <changeSet id="20260427120000-1" author="mercotrace">
        <addColumn tableName="auction_entry">
            <column name="summary_seller_rate" type="numeric(19, 2)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260427120000-2" author="mercotrace">
        <sql dbms="postgresql">
            UPDATE auction_entry SET summary_seller_rate = seller_rate WHERE summary_seller_rate IS NULL;
        </sql>
    </changeSet>

    <changeSet id="20260427120000-3" author="mercotrace">
        <addNotNullConstraint tableName="auction_entry" columnName="summary_seller_rate" columnDataType="numeric(19, 2)"/>
    </changeSet>
</databaseChangeLog>
